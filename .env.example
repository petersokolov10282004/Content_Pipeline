# ─── Database ────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/contentpipeline
DB_USERNAME=contentpipeline
DB_PASSWORD=contentpipeline

# ─── Temporal ────────────────────────────────────────────────────────────────
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
# Get from: Cloudflare dashboard → R2 → Manage R2 API tokens
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=contentpipeline
# R2 endpoint: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── FFmpeg ───────────────────────────────────────────────────────────────────
RENDER_FFMPEG_PATH=/usr/bin/ffmpeg
RENDER_TEMP_DIR=/tmp/contentpipeline/renders

# ─── YouTube (Phase 7 — leave blank until OAuth is implemented) ───────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_DEFAULT_PRIVACY=PRIVATE

# ─── Spring Profiles ─────────────────────────────────────────────────────────
# dev (default): mock YouTube upload, permissive security
# prod: real YouTube upload, JWT security
SPRING_PROFILES_ACTIVE=dev

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_AUTH_ENABLED=false
